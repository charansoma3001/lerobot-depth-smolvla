+# Key under which the depth target is stored in the training batch (added by the C2 training script; absent for C1).
+OBS_DEPTH = "observation.depth"
+
+class DepthReconstructionHead(nn.Module):
+    """Auxiliary head that reconstructs a coarse depth map from the image tokens (C2).
+
+    If the same features the policy uses to pick actions can also be decoded back into the scene's depth, then those features must carry 3D spatial
+    information.
+
+    It reads the 64 connector tokens SmolVLA already produces per image. Those tokens are in row-major over an 8x8 grid that covers the
+    (square, top-padded) image, so token t sits at row t // 8, column t % 8. One linear layer maps each token to one depth value, giving an
+    8x8 depth image, which is then bilinearly upsampled to the target resolution (64x64).
+    """
+
+    def __init__(self, hidden_size: int, target_size: int):
+        super().__init__()
+        # One linear layer, shared across all tokens, turning each token into a single depth number.
+        self.proj = nn.Linear(hidden_size, 1)
+        self.target_size = target_size
+
+    def forward(self, image_tokens: Tensor) -> Tensor:
+        # image_tokens: (B, num_tokens, hidden). num_tokens is a perfect square (64), which we reshape back into the 2D grid the tokens came from.
+        bsize, num_tokens, _ = image_tokens.shape
+        grid = int(round(num_tokens**0.5))
+        if grid * grid != num_tokens:
+            raise ValueError(f"Expected a square token grid, got {num_tokens} tokens.")
+        x = self.proj(image_tokens)  # (B, num_tokens, 1): one depth value per token
+        x = x.view(bsize, 1, grid, grid)  # (B, 1, grid, grid): row-major = image layout
+        # Upsample the grid to the target size so it can be compared against the 64x64 depth ground truth pixel for pixel.
+        x = F.interpolate(
+            x.to(dtype=torch.float32),
+            size=(self.target_size, self.target_size),
+            mode="bilinear",
+            align_corners=False,
+        )
+        return x[:, 0]  # (B, target_size, target_size)
+
